# KVM Ubuntu VM Configuration
# Copy this file to config.env and modify the values:
#   cp config.env.example config.env

# --- VM Specification ---
VM_NAME="ubuntu-server"
VM_CPUS=2
VM_MEMORY=4096              # MB
VM_DISK_SIZE=20             # GB

# --- Guest OS ---
VM_USER="wpsweb"
UBUNTU_VERSION="24.04"

# --- Network ---
NETWORK_MODE="nat"          # nat | bridge
BRIDGE_NAME="br0"           # Only used when NETWORK_MODE=bridge

# --- Storage ---
DATA_DIR="${HOME}/.kvm-ubuntu"

# --- Image Source ---
UBUNTU_IMAGE_BASE_URL="https://cloud-images.ubuntu.com/releases"

# --- Flags ---
AUTO_YES=0                  # Set to 1 to skip all confirmation prompts

# --- APT Mirror ---
APT_MIRROR=                 # ustc/tsinghua/aliyun/huawei or custom URL

# --- China Mode ---
CN_MODE=0                   # 1=enable China mirrors/proxies automatically
GITHUB_PROXY=               # GitHub accelerator prefix (e.g. https://ghfast.top/)
