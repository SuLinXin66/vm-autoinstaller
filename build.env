# =============================================================================
# build.env — 构建变量（fork/定制时只需修改此文件）
# =============================================================================

# --- 项目信息 ---
APP_NAME=kvm-ubuntu
REPO_URL=https://github.com/SuLinXin66/vm-autoinstaller
BRANCH=main

# --- VM 默认配置 ---
# 以下值会注入 CLI 二进制和 config.env.example，用户安装后可通过 config.env 覆盖

# VM 名称（libvirt/VirtualBox 中的显示名）
DEFAULT_VM_NAME=kvm-ubuntu-server

# CPU 核数（0 = 自动匹配宿主机逻辑核数）
DEFAULT_VM_CPUS=0

# 内存大小（MB）
DEFAULT_VM_MEMORY=2048

# 磁盘大小（GB）
DEFAULT_VM_DISK_SIZE=20

# VM 登录用户名
DEFAULT_VM_USER=kvm-ubuntu

# Ubuntu 版本
DEFAULT_UBUNTU_VERSION=24.04

# 网络模式：nat | bridge
DEFAULT_NETWORK_MODE=nat

# 桥接网卡名（仅 NETWORK_MODE=bridge 时使用）
DEFAULT_BRIDGE_NAME=br0

# Ubuntu Cloud Image 下载源
DEFAULT_UBUNTU_IMAGE_BASE_URL=https://cloud-images.ubuntu.com/releases

# 是否跳过确认提示（0=否, 1=是）
DEFAULT_AUTO_YES=0

# 是否强制资源下限（1=是, 0=否）
# 启用后，使用者通过 config set 修改 CPU/内存/磁盘时不能低于上述默认值
DEFAULT_ENFORCE_RESOURCE_LIMIT=1

# 内置共享目录（编译固化，用户不可删除/禁用）
# 格式: 宿主机路径:VM挂载点[:ro]  多个用逗号分隔
# 路径中的 ~ 会自动解析（宿主机→宿主机家目录，VM→VM用户家目录）
# 留空则不启用内置共享
DEFAULT_BUILTIN_SHARES=

# APT 镜像源（留空=官方源，可填预置名: ustc/tsinghua/aliyun/huawei，或自定义 URL）
# 同时影响 Ubuntu 源和 Docker CE 源
DEFAULT_APT_MIRROR=

# 国内模式（1=开启，自动使用国内镜像/加速站；0=关闭）
# 开启后自动联动: APT_MIRROR→ustc, GITHUB_PROXY→ghfast.top, Chrome→Chromium
# 用户显式设置的 APT_MIRROR / GITHUB_PROXY 优先于 CN_MODE 的默认值
DEFAULT_CN_MODE=1

# GitHub 加速前缀（如 https://ghfast.top/）
# CN_MODE=1 时自动为 https://ghfast.top/，也可单独设置
DEFAULT_GITHUB_PROXY=

# SSH 映射（0=关闭, 1=开启）
# 开启后将宿主机 ~/.ssh 挂载到 VM ~/.ssh-host，自动 symlink 密钥 + Include 配置
DEFAULT_SSH_FORWARD=0

# Chrome 跳过首次运行体验（0=正常显示, 1=跳过登录引导和默认浏览器检测）
DEFAULT_CHROME_NO_FIRST_RUN=1

# --- Windows Hypervisor ---
# 虚拟化后端选择（auto=自动检测, hyperv=强制Hyper-V, vbox=强制VirtualBox）
# auto 模式下：Pro/Enterprise/Education 使用 Hyper-V，Home 回退 VirtualBox
DEFAULT_HYPERVISOR=auto

# VM 停止后自动关闭 Hyper-V 服务以释放资源（0=否, 1=是）
DEFAULT_HYPERV_AUTO_STOP_SERVICE=0
